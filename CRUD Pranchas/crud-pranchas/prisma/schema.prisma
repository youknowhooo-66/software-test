generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Prancha {
  id        Int      @id @default(autoincrement())
  nome      String
  modelo    String?
  tamanho   String   // ex: 6'2
  tipo      String   // shortboard, longboard, fish...
  preco     Decimal? @db.Decimal(10,2)
  status    String   @default("DISPONIVEL") // DISPONIVEL, VENDIDA
  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}